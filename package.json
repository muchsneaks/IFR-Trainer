{
  "name": "msfs-ifr-trainer",
  "version": "1.0.0",
  "description": "IFR moving-map trainer for Microsoft Flight Simulator 2024. Live flight track on an IFR-style chart with VORs, NDBs, waypoints and airports read from the native MSFS facility database via SimConnect. Ships as a Windows desktop app and an in-sim MSFS toolbar panel.",
  "main": "electron/main.js",
  "author": "JoyBuy",
  "scripts": {
    "start": "node server/index.js",
    "demo": "node server/index.js --demo",
    "app": "electron .",
    "app:demo": "electron . --demo",
    "layout": "node msfs-addon/build-layout.js",
    "dist": "npm run layout && electron-builder --win --x64",
    "dist:dir": "electron-builder --win --dir"
  },
  "keywords": [
    "msfs",
    "msfs2024",
    "simconnect",
    "ifr",
    "moving-map",
    "flight-simulator"
  ],
  "license": "MIT",
  "dependencies": {
    "leaflet": "^1.9.4",
    "node-simconnect": "^4.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.joybuy.msfs.ifrtrainer",
    "productName": "IFR Trainer",
    "artifactName": "IFR-Trainer-Setup-${version}.${ext}",
    "copyright": "Copyright © 2026 JoyBuy",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "build/icon.*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "msfs-addon",
        "to": "msfs-addon",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IFR Trainer"
    }
  }
}
